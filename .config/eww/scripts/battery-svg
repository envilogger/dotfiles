#!/bin/bash

BAT=$(ls /sys/class/power_supply | grep BAT | head -n 1)
capacity=$(cat /sys/class/power_supply/"$BAT"/capacity)
status=$(cat /sys/class/power_supply/"$BAT"/status)

# Clamp capacity 0-100
(( capacity > 100 )) && capacity=100
(( capacity < 0 )) && capacity=0

# Fill color: red when <20%, green otherwise
if (( capacity < 20 )); then
  fill="#e04040"
else
  fill="#40c040"
fi

# Fill width: proportional to capacity within the body interior (max ~18px inside the 22px body)
fill_w=$(awk "BEGIN { printf \"%.1f\", 18 * $capacity / 100 }")

# Lightning bolt overlay when charging and < 95%
bolt=""
if [[ "$status" != "Discharging" ]]; then
  bolt='<path d="M13 0 L9 10 L12.5 10 L10 18 L16 8 L12.5 8 Z" fill="#4c4f69" stroke="#4c4f69" stroke-width="0.5"/>'
fi

cat > /tmp/eww-battery.svg <<EOF
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 18">
  <!-- battery body -->
  <rect x="1" y="3" width="22" height="12" rx="2" ry="2" fill="none" stroke="#4c4f69" stroke-width="1.2"/>
  <!-- battery nub -->
  <rect x="23.5" y="6" width="2.5" height="6" rx="1" ry="1" fill="#4c4f69"/>
  <!-- fill -->
  <rect x="3" y="5" width="$fill_w" height="8" rx="1" ry="1" fill="$fill"/>
  $bolt
</svg>
EOF

echo "/tmp/eww-battery.svg"
